# ===========================================
# Fors8 Environment Configuration
# ===========================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ===== AI Provider (OpenRouter — free models available) =====
LLM_API_KEY=your_openrouter_api_key_here
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL_NAME=google/gemma-3-27b-it:free

# ===== ZEP Memory Graph (optional) =====
# Free tier is sufficient for basic use: https://app.getzep.com/
ZEP_API_KEY=your_zep_cloud_api_key_here

# ===== Boost LLM (optional — faster secondary model) =====
# Leave these out entirely if not using a boost model
# LLM_BOOST_API_KEY=
# LLM_BOOST_BASE_URL=
# LLM_BOOST_MODEL_NAME=

# ===== Vast.ai GPU Cloud (for 100K+ agent simulations) =====
VASTAI_API_KEY=your_vastai_api_key_here
VASTAI_MAX_SPEND_PER_RUN=6.00
VASTAI_MAX_INSTANCES=2
VASTAI_AUTO_DESTROY_MINUTES=30
VASTAI_MAX_PRICE_PER_HOUR=4.00

# ===== GPU / vLLM inference =====
# VLLM_ENDPOINT is auto-set by the GPU lifecycle manager — leave empty
VLLM_ENDPOINT=
VLLM_MODEL=qwen2.5:32b
# GPU_IDLE_TIMEOUT_SECONDS=10800

# ===== PostgreSQL (optional — enables chat history persistence) =====
DATABASE_URL=dbname=fors8 host=localhost

# ===== Dual-LLM bias mitigation (optional) =====
DUAL_LLM_ENABLED=false
DUAL_LLM_API_KEY=
DUAL_LLM_BASE_URL=https://api.deepseek.com/v1
DUAL_LLM_MODEL_NAME=deepseek-chat

# ===== Data-source API keys (all optional) =====
# NEWSAPI_KEY=
# YOUTUBE_API_KEY=
# NEWSDATA_KEY=
# GNEWS_KEY=
# MEDIASTACK_KEY=
# ACLED_EMAIL=
# ACLED_KEY=
# TWITTER_BEARER_TOKEN=
# TELEGRAM_API_ID=
# TELEGRAM_API_HASH=
